{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "CommonJS",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "paths": {
      "*": ["node_modules/*"]
    },
    "lib": ["WebWorker", "ES6", "ScriptHost", "DOM"],
  },
  "include": ["src/**/*", "utility_plugin.ts", "shared", "types.d.ts"],
}
